{
  "manifest_version": 3,
  "name": "Tabs Mgr.",
  "version": "2.0",
  "description": "A local Chrome new tab dashboard for browsing, refreshing, and saving your open tabs.",
  "permissions": ["tabs", "activeTab", "storage"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tabs Mgr.",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
